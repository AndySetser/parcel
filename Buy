  if(!faqList) return;
  faqList.innerHTML = faqs.map(f => `<div class="faq-item"><div class="faq-q">${f.q}<span class="plus">+</span></div><div class="faq-a">${f.a}</div></div>`).join('');
  faqList.querySelectorAll('.faq-item').forEach(item=>{
    item.querySelector('.faq-q').addEventListener('click', ()=> item.classList.toggle('open'));
  });
}

/* ---------------- post-render wiring ---------------- */
function afterRender(route, parts){
  if(route === 'buy'){
    renderBuyResults();
    document.getElementById('buyFilter').addEventListener('input', renderBuyResults);
  }
  if(route === 'board'){
    renderCorkboard();
    document.getElementById('boardInput').addEventListener('keydown', e=>{ if(e.key==='Enter') submitPin(); });
  }
  if(route === 'signal'){
    const btn = document.getElementById('followBtn');
    if(btn){
      btn.addEventListener('click', ()=>{
        const p = PINS.find(x=>x.id===parseInt(parts[1]));
        if(!p) return;
        p.following = !p.following;
        btn.textContent = p.following ? 'Following ✓' : 'Follow this signal';
        btn.classList.toggle('following', p.following);
      });
    }
  }
  if(route === 'guide') startGuide();
  if(route === 'faq') renderFaq();
}
</script>
</body>
</html>
